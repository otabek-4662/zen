{
  "name": "claude-telegram-desktop",
  "version": "1.0.0",
  "description": "A minimalist Claude AI-themed Telegram desktop client built with Electron",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && shx cp -r src/renderer dist/renderer",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": ["telegram", "electron", "claude", "desktop"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "shx": "^0.3.4",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.otabek.claudetelegram",
    "productName": "ClaudeTelegram",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    }
  }
}
